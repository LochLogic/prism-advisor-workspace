{
  "name": "prism-advisor-workspace",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "check": "node scripts/check.mjs",
    "lint": "node scripts/lint.mjs",
    "test": "npm run build && npm run check && npm run test:calc",
    "test:quiet": "npm run build && node scripts/check.mjs --quiet && node scripts/calc.test.mjs --quiet",
    "test:calc": "node scripts/calc.test.mjs",
    "test:db": "node scripts/db-test.mjs",
    "test:rls": "node scripts/rls-test.mjs",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "supabase": "^2.106.0",
    "wrangler": "^4.100.0"
  }
}
